def func_a(scores): # 선택정렬

    for i in range(len(scores) - 1):
        max_idx = i
        for j in range(i + 1, len(scores)):
            if scores[j] > scores[max_idx]:
                max_idx = j

        tmp = scores[i]
        scores[i] = scores[max_idx]
        scores[max_idx] = tmp

    return scores

def func_a(scores): # 버블정렬

    for i in range(len(scores), 0, -1):
        for j in range(i - 1):
            if scores[j] < scores[j + 1]:

                scores[j], scores[j + 1] = scores[j + 1], scores[j] # 값의 교환에 사용할 수 있는 파이썬 방식
    
    return scores

           
def solution(scores, n):
    n_score = scores[n]
    
    sorted_scores = func_a(scores)

    for i in range(len(sorted_scores)):
        if sorted_scores[i] == n_score:
            return i + 1

