''' 3번
def solution(scores):

    scores.sort() # 리스트 이름.sort() 를 써서 값들을 오름차순 정렬할 수 있다. (reverse = True) 를 사용하면 내림차순.

    scores_sum = sum(scores[1:-1]) # 슬라이싱으로 인덱스를 활용해 리스트의 부분을 추출할 수 있다. sum(   ) 을 사용해 여러 값, 리스트의 합을 구할 수 있다.

    result = scores_sum // (len(scores) - 2) # 몫을 취하는 것으로 소수점 제거.

    return result

