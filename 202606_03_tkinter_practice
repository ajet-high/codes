# 6. grid
import tkinter as tk

root = tk.Tk()

tk.Button(root, text="1").grid(row=0, column=0)
tk.Button(root, text="2").grid(row=0, column=1)
tk.Button(root, text="3").grid(row=1, column=0)

root.mainloop()


# 7. place
import tkinter as tk

root = tk.Tk()
root.geometry("300x200")

tk.Button(root, text="버튼").place(x=100, y=50)

root.mainloop()


# 8. config
import tkinter as tk

def change():
    label.config(text="변경 완료")

root = tk.Tk()

label = tk.Label(root, text="원래 글자")
label.pack()

tk.Button(root, text="변경", command=change).pack()

root.mainloop()


# 9. after
import tkinter as tk

def message():
    label.config(text="3초 지남")

root = tk.Tk()

label = tk.Label(root, text="대기 중")
label.pack()

root.after(3000, message)

root.mainloop()


# 10. destroy
import tkinter as tk

root = tk.Tk()

tk.Button(root, text="닫기", command=root.destroy).pack()

root.mainloop()
