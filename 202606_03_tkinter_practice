# 1. Label
import tkinter as tk

root = tk.Tk()

tk.Label(root, text="안녕하세요").pack()

root.mainloop()


# 2. Button
import tkinter as tk

def hello():
    print("버튼 클릭")

root = tk.Tk()

tk.Button(root, text="클릭", command=hello).pack()

root.mainloop()


# 3. Entry
import tkinter as tk

def show():
    print(entry.get())

root = tk.Tk()

entry = tk.Entry(root)
entry.pack()

tk.Button(root, text="확인", command=show).pack()

root.mainloop()


# 4. Text
import tkinter as tk

